# === Auth (REQUIRED) ===
JWT_SECRET=                  # REQUIRED — python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_PASSWORD=              # Set after first run (printed to console)

# === Discord Bot (REQUIRED) ===
DISCORD_BOT_TOKEN=           # From Discord Developer Portal → Bot → Token
DISCORD_CHANNEL_ID=          # Legacy fallback — Right-click channel → Copy ID
DISCORD_WEBHOOK_URL=         # Optional: webhook URL for engine alerts

# === Discord OAuth (REQUIRED for subscribe flow) ===
DISCORD_CLIENT_ID=           # From Discord Developer Portal → OAuth2 → Client ID
DISCORD_CLIENT_SECRET=       # From Discord Developer Portal → OAuth2 → Client Secret
DISCORD_REDIRECT_URI=https://api.canary.heuricity.com/api/auth/discord/callback
# NOTE: You must add BOTH redirect URIs in Discord Developer Portal → OAuth2 → Redirects:
#   1. https://api.canary.heuricity.com/api/auth/discord/callback        (web subscribe flow)
#   2. https://api.canary.heuricity.com/api/auth/discord/desktop/callback (desktop app login)

# === Stripe (REQUIRED for payments) ===
STRIPE_SECRET_KEY=           # From Stripe Dashboard → API keys (use live key in production)
STRIPE_WEBHOOK_SECRET=       # From Stripe Dashboard → Webhooks → Signing secret
STRIPE_CONNECT_CLIENT_ID=    # For partner Connect onboarding (optional initially)

# === Server ===
HOST=0.0.0.0
PORT=8000
DB_PATH=data/pkc.db
CORS_ORIGINS=https://canary.heuricity.com,https://www.canary.heuricity.com

# === Detection Tuning ===
HOMEPAGE_POLL_INTERVAL=5     # seconds
SITEMAP_POLL_INTERVAL=60    # seconds
CATALOG_POLL_INTERVAL=120   # seconds
SOCIAL_POLL_INTERVAL=300    # seconds (Reddit RSS)

# === LLM (optional — enables weekly recaps, post-mortems, narratives) ===
LLM_PROVIDER=anthropic       # "anthropic" or "openai"
ANTHROPIC_API_KEY=           # From console.anthropic.com
OPENAI_API_KEY=              # From platform.openai.com
